## Copia este archivo a .env y completa tus credenciales. NO subir el .env con credenciales reales.

BROWSERSTACK_USERNAME=your_browserstack_username
BROWSERSTACK_ACCESS_KEY=your_browserstack_access_key
BROWSERSTACK_PROJECT=PlayWright Tests
BROWSERSTACK_BUILD=local-build-1
BROWSERSTACK_BROWSER=chrome
BROWSERSTACK_BROWSER_VERSION=latest
BROWSERSTACK_OS=OS X
BROWSERSTACK_OS_VERSION=Monterey
